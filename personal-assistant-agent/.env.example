# --- LLM provider (pick one) ---
# ollama | groq | nvidia | openai  (auto-detected if omitted)
# LLM_PROVIDER=ollama

# === Option A: Ollama (free, runs on your Mac, no API billing) ===
# 1. Install: https://ollama.com
# 2. Run: ollama pull llama3.1
# 3. Uncomment:
# LLM_PROVIDER=ollama
# OPENAI_MODEL=llama3.1

# === Option B: Groq (free cloud tier, fast) ===
# Get key: https://console.groq.com/keys
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.3-70b-versatile

# === Option C: NVIDIA NIM (free credits on build.nvidia.com) ===
# LLM_PROVIDER=nvidia
# NVIDIA_API_KEY=nvapi-...
# OPENAI_MODEL=meta/llama-3.3-70b-instruct

# === Option D: OpenAI (paid / limited free trial) ===
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Google OAuth (required for email + calendar) ---
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=http://localhost:8080
TOKEN_PATH=token.json
