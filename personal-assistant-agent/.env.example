# --- LLM (defaults to Ollama — no API key required) ---
LLM_PROVIDER=ollama
# Faster local default (pull once: ollama pull llama3.2:3b)
OPENAI_MODEL=llama3.2:3b
# Do NOT set OPENAI_BASE_URL for Ollama unless it is localhost:11434.
# A leftover Groq URL here causes 401 Invalid API Key during live eval.
# Or use Groq for much faster cloud inference:
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.1-8b-instant
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Other providers:
# NVIDIA: LLM_PROVIDER=nvidia  NVIDIA_API_KEY=nvapi-...
# OpenAI: LLM_PROVIDER=openai  OPENAI_API_KEY=sk-...

# --- Performance tuning (optional) ---
# GMAIL_MAX_RESULTS=5
# GOOGLE_CACHE_TTL_SEC=60
# EMAIL_SNIPPET_MAX_CHARS=120
# DEBUG_TIMING=1

# --- Google OAuth (required for email + calendar) ---
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=http://localhost:8080
TOKEN_PATH=token.json

# Optional: IANA timezone (defaults to your Mac's timezone)
# Austin, TX example:
# LOCAL_TIMEZONE=America/Chicago
